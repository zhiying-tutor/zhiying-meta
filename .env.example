# 反向代理对外暴露用的公网主机名（仅域名/IP，无 scheme）
PUBLIC_HOST=example.com

# PostgreSQL
POSTGRES_USER=zhiying
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=zhiying_backend

# RabbitMQ
RABBITMQ_USER=zhiying
RABBITMQ_PASSWORD=please-change-me

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_TTL_DAYS=30

# 微服务回调 API Key（必须 sk- 开头，前后端/微服务保持一致）
KNOWLEDGE_VIDEO_API_KEY=sk-knowledge-video-prod
CODE_VIDEO_API_KEY=sk-code-video-prod
INTERACTIVE_HTML_API_KEY=sk-interactive-html-prod
KNOWLEDGE_EXPLANATION_API_KEY=sk-knowledge-explanation-prod
PRETEST_API_KEY=sk-pretest-prod
PLAN_API_KEY=sk-plan-prod
QUIZ_API_KEY=sk-quiz-prod
RECHARGE_API_KEY=sk-recharge-prod

# 阿里云 OSS（香港区为例：oss-cn-hongkong）
STORAGE_ENDPOINT=https://oss-cn-hongkong.aliyuncs.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=oss-cn-hongkong
STORAGE_BUCKET=zhiying-content
# 浏览器实际访问对象用的前缀；可填 OSS bucket 自带域名或前置 CDN 域名
STORAGE_PUBLIC_BASE=https://zhiying-content.oss-cn-hongkong.aliyuncs.com

# 经济参数（可选，留空走 compose 默认）
# REGISTER_BONUS_DIAMONDS=80
# CHECKIN_REWARD_SEQUENCE=1,2,3,4,6,8,10
# CHECKIN_MAKEUP_GOLD_COST_PER_DAY=50
# CHECKIN_MAKEUP_DIAMOND_COST=1
# KNOWLEDGE_VIDEO_DIAMOND_COST=5
# CODE_VIDEO_DIAMOND_COST=5
# INTERACTIVE_HTML_GOLD_COST=10
# KNOWLEDGE_EXPLANATION_GOLD_COST=10
# STUDY_SUBJECT_DIAMOND_COSTS=3:10,7:20,15:40,30:80
# STUDY_QUIZ_FREE_LIMIT_PER_TASK=3
# STUDY_QUIZ_EXTRA_GOLD_COST=20

# Mocks（可选）
# MOCK_GENERATING_DELAY_MS=500
# MOCK_FINISHED_DELAY_MS=3000
# MOCK_FAILURE_RATE=0.0
# MOCK_PREFETCH=16
